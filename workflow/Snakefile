import pandas as pd
from pathlib import Path

configfile: "config/config.yaml"


SAMPLES = pd.read_csv(config["input"]["samples_tsv"], sep="\t").set_index("sample", drop=False)
CONTRASTS = pd.read_csv(config["input"]["contrasts_tsv"], sep="\t").set_index("contrast_id", drop=False)

SAMPLE_IDS = SAMPLES["sample"].tolist()
CONTRAST_IDS = CONTRASTS["contrast_id"].tolist()

RESULTS = Path("results")


wildcard_constraints:
    contrast="[A-Za-z0-9_.-]+",
    sample="[A-Za-z0-9_.-]+",


include: "rules/qc.smk"
include: "rules/de.smk"
include: "rules/enrichment.smk"
include: "rules/report.smk"


rule all:
    input:
        RESULTS / "qc" / "qc_summary.tsv",
        RESULTS / "exploratory" / "pca.rds",
        expand(RESULTS / "de" / "{contrast}" / "deseq2_results.csv", contrast=CONTRAST_IDS),
        expand(RESULTS / "enrichment" / "{contrast}" / "gsea_combined.csv", contrast=CONTRAST_IDS),
        expand(RESULTS / "enrichment" / "{contrast}" / "ora_combined.csv", contrast=CONTRAST_IDS),
        expand(RESULTS / "tf_activity" / "{contrast}" / "tf_scores.tsv", contrast=CONTRAST_IDS),
        expand(RESULTS / "pathway_activity" / "{contrast}" / "progeny_scores.tsv", contrast=CONTRAST_IDS),
        expand(RESULTS / "drug_repositioning" / "{contrast}" / "l2s2_hits.tsv", contrast=CONTRAST_IDS),
        RESULTS / "report" / "report.html",
